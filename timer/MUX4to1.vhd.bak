LIBRARY ieee;
USE ieee.std_logic_1164.ALL;

ENTITY MUX4_TO_1 IS
    PORT (
        S0, S1 : IN std_logic;      -- Select lines
        T0, T1, T2, T3 : IN std_logic; -- Input data lines
        Y : OUT std_logic   -- Output
    );
END MUX4_TO_1;

ARCHITECTURE behavioral OF MUX4_TO_1 IS
BEGIN
    PROCESS (S0, S1, T0, T1, T2, T3)
    BEGIN
        CASE (S1 & S0) IS
            WHEN "00" => 
                Y <= T0;  -- Output T0 when S1S0 = 00
            WHEN "01" => 
                Y <= T1;  -- Output T1 when S1S0 = 01
            WHEN "10" => 
                Y <= T2;  -- Output T2 when S1S0 = 10
            WHEN "11" => 
                Y <= T3;  -- Output T3 when S1S0 = 11
            WHEN OTHERS => 
                Y <= '0';  -- Default case, output 0 if any other condition occurs
        END CASE;
    END PROCESS;
END behavioral;

