library IEEE;
use IEEE.STD_LOGIC_1164.ALL;
use IEEE.NUMERIC_STD.ALL;

entity Memory is
    Port (
        address     : in  STD_LOGIC_VECTOR(11 downto 0);
        instruction : out STD_LOGIC_VECTOR(15 downto 0)
    );
end Memory;

architecture Behavioral of Memory is
    type ROM_Array is array (0 to 7) of STD_LOGIC_VECTOR(15 downto 0);
    signal ROM : ROM_Array := (
        0 => "0000" & "000100000000", -- LDA @100h
        1 => "0010" & "000100000001", -- ADD @101h
        2 => "0110" & "000000000101", -- JNE 005h
        3 => "0011" & "000100000000", -- SUB @100h
        4 => "0011" & "000100000000", -- SUB @100h
        5 => "0010" & "000100000000", -- ADD @100h
        6 => "0111" & "000000000000", -- STP
        others => (others => '0')
    );
begin
    process(address)
    begin
        instruction <= ROM(to_integer(unsigned(address)));
    end process;
end Behavioral;

